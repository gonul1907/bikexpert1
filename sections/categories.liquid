        <span style="display:block; padding:0.6rem; font-weight:700; font-size:0.82rem; color:#111; text-align:center;">Jongensfietsen</span>
      </a>

      <!-- Meisjesfietsen -->
      <a href="/collections/meisjesfietsen" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; background:#f7f7f7; border-radius:10px; overflow:hidden; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.boxShadow='none'">
        <img src="https://images.unsplash.com/photo-1520872024865-3ff2805d8bb3?w=400&q=80&auto=format&fit=crop" alt="Meisjesfietsen" style="width:100%; height:110px; object-fit:cover;">
