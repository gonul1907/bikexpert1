<!-- -- Categorie�n -- -->
<section style="background:#fff; padding:2.5rem 0;">
  <div style="max-width:1280px; margin:0 auto; padding:0 1.25rem;">

    <h2 style="font-size:1.4rem; font-weight:800; color:#111; margin:0 0 1.5rem;">Shop per categorie</h2>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(140px,1fr)); gap:1rem;">

      <!-- Elektrische fietsen -->
      <a href="/collections/elektrische-fietsen" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; background:#f7f7f7; border-radius:10px; overflow:hidden; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.boxShadow='none'">
        <img src="https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=400&q=80&auto=format&fit=crop" alt="Elektrische fietsen" style="width:100%; height:110px; object-fit:cover;">
        <span style="display:block; padding:0.6rem; font-weight:700; font-size:0.82rem; color:#111; text-align:center;">Elektrische fietsen</span>
      </a>

      <!-- Bakfiets -->
      <a href="/collections/bakfiets" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; background:#f7f7f7; border-radius:10px; overflow:hidden; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.boxShadow='none'">
        <img src="https://voguebike.com/wp-content/uploads/2023/09/VOGUE-AVENGER-MATT-BLACK-BLACK.jpg" alt="Bakfietsen" style="width:100%; height:110px; object-fit:cover;">
        <span style="display:block; padding:0.6rem; font-weight:700; font-size:0.82rem; color:#111; text-align:center;">Bakfietsen</span>
      </a>

