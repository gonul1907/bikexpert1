<!--
  SECTION: sections/testimonials.html
  Shopify: {% section 'testimonials' %}
-->
<section class="section bg-bx-dark text-white" aria-labelledby="testimonials-heading">
  <div class="bx-container">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="section-label text-white/50" data-animate>Wat onze klanten zeggen</p>
      <h2 id="testimonials-heading" class="text-display-md font-black tracking-tight mt-2" data-animate style="animation-delay:0.05s">
        Beoordelingen
      </h2>
      <!-- Aggregate score -->
      <div class="flex items-center justify-center gap-3 mt-5" data-animate style="animation-delay:0.1s">
        <div class="flex gap-1">
          {% for i in (1..5) %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-bx-accent" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endfor %}
        </div>
        <span class="text-white font-bold">9.4 / 10</span>
        <span class="text-white/40 text-sm">op basis van 284 beoordelingen</span>
      </div>
    </div>

    <!-- Reviews grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Review 1 -->
      <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-7 space-y-4" data-animate>
        <div class="flex gap-1">
          {% for i in (1..5) %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-bx-accent" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endfor %}
        </div>
        <p class="text-white/80 text-sm leading-relaxed">
          "Geweldig geholpen bij de aanschaf van mijn e-bike. Echt persoonlijk advies, niet zomaar een product verkopen. De monteur heeft alles perfect ingesteld."
        </p>
        <footer class="flex items-center gap-3 pt-2 border-t border-white/10">
          <div class="w-9 h-9 rounded-full bg-bx-accent/20 flex items-center justify-center text-bx-accent font-bold text-sm">ML</div>
          <div>
            <p class="text-sm font-semibold text-white">Marieke L.</p>
            <p class="text-xs text-white/40">Gazelle Ultimate C380 HMB</p>
          </div>
        </footer>
      </blockquote>

      <!-- Review 2 -->
      <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-7 space-y-4" data-animate style="animation-delay:0.08s">
        <div class="flex gap-1">
          {% for i in (1..5) %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-bx-accent" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endfor %}
        </div>
        <p class="text-white/80 text-sm leading-relaxed">
          "Onze Trek racefietsen zijn hier gekocht en we zijn super tevreden! De service na verkoop is ook uitstekend. Volgende week terug voor het eerste onderhoud."
        </p>
        <footer class="flex items-center gap-3 pt-2 border-t border-white/10">
          <div class="w-9 h-9 rounded-full bg-bx-accent/20 flex items-center justify-center text-bx-accent font-bold text-sm">PV</div>
          <div>
            <p class="text-sm font-semibold text-white">Peter V.</p>
            <p class="text-xs text-white/40">Trek Domane AL 4</p>
          </div>
        </footer>
      </blockquote>

      <!-- Review 3 -->
      <blockquote class="bg-white/5 border border-white/10 rounded-2xl p-7 space-y-4" data-animate style="animation-delay:0.16s">
        <div class="flex gap-1">
          {% for i in (1..5) %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-bx-accent" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endfor %}
        </div>
        <p class="text-white/80 text-sm leading-relaxed">
          "Zat al een tijd te twijfelen over een e-bike. Na het bezoek aan Bikexpert wist ik het meteen. De testrit heeft me overtuigd en de levering was supersnel!"
        </p>
        <footer class="flex items-center gap-3 pt-2 border-t border-white/10">
          <div class="w-9 h-9 rounded-full bg-bx-accent/20 flex items-center justify-center text-bx-accent font-bold text-sm">SA</div>
          <div>
            <p class="text-sm font-semibold text-white">Sandra A.</p>
            <p class="text-xs text-white/40">Batavus Finez E-Go Super</p>
          </div>
        </footer>
      </blockquote>
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a href="/pages/over-ons#reviews" class="btn-outline-white btn">
        Alle reviews bekijken
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beoordelingen",
  "settings": []
}
{% endschema %}
