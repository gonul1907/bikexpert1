<section class="section bg-bx-white" aria-labelledby="collections-heading">
  <div class="bx-container">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <p class="section-label" data-animate>Shop per categorie</p>
        <h2 id="collections-heading" class="text-display-md font-black tracking-tight text-balance" data-animate style="animation-delay:0.05s">
          Uitgelichte collecties
        </h2>
      </div>
      <a href="/collections/all" class="btn-outline btn self-start md:self-auto flex-shrink-0" data-animate style="animation-delay:0.1s">
        Alle collecties bekijken
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Jongensfietsen -->
      <a href="/collections/jongensfietsen" class="group relative block rounded-2xl overflow-hidden aspect-[4/5] bg-bx-gray" data-animate>
        <img
          src="https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?w=600&q=80&auto=format&fit=crop"
          alt="Jongensfietsen"
          width="600" height="750"
          loading="lazy" decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <p class="text-xs text-bx-accent font-semibold uppercase tracking-widest mb-1">Collectie</p>
          <h3 class="text-white font-black text-xl leading-tight mb-3">Jongensfietsen</h3>
          <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
            Bekijk collectie
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </div>
      </a>

      <!-- Meisjesfietsen -->
      <a href="/collections/meisjesfietsen" class="group relative block rounded-2xl overflow-hidden aspect-[4/5] bg-bx-gray" data-animate style="animation-delay:0.07s">
        <img
          src="https://images.unsplash.com/photo-1520872024865-3ff2805d8bb3?w=600&q=80&auto=format&fit=crop"
          alt="Meisjesfietsen"
          width="600" height="750"
          loading="lazy" decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <p class="text-xs text-bx-accent font-semibold uppercase tracking-widest mb-1">Collectie</p>
          <h3 class="text-white font-black text-xl leading-tight mb-3">Meisjesfietsen</h3>
          <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
            Bekijk collectie
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </div>
      </a>

      <!-- Fatbikes -->
      <a href="/collections/fatbikes" class="group relative block rounded-2xl overflow-hidden aspect-[4/5] bg-bx-gray" data-animate style="animation-delay:0.14s">
        <img
          src="https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=600&q=80&auto=format&fit=crop"
          alt="Fatbikes"
          width="600" height="750"
          loading="lazy" decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <p class="text-xs text-bx-accent font-semibold uppercase tracking-widest mb-1">Collectie</p>
          <h3 class="text-white font-black text-xl leading-tight mb-3">Fatbikes</h3>
          <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
            Bekijk collectie
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </div>
      </a>

      <!-- Vogue fietsen -->
      <a href="/collections/vogue-fietsen" class="group relative block rounded-2xl overflow-hidden aspect-[4/5] bg-bx-gray" data-animate style="animation-delay:0.21s">
        <img
          src="https://images.unsplash.com/photo-1507035895480-2b3156c31fc8?w=600&q=80&auto=format&fit=crop"
          alt="Vogue fietsen"
          width="600" height="750"
          loading="lazy" decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <p class="text-xs text-bx-accent font-semibold uppercase tracking-widest mb-1">Collectie</p>
          <h3 class="text-white font-black text-xl leading-tight mb-3">Vogue fietsen</h3>
          <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
            Bekijk collectie
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Uitgelichte collecties",
  "settings": []
}
{% endschema %}
