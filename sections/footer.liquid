<!-- -- Footer -- -->
<footer style="background:#1a1a1a; color:#ccc; padding:3rem 1.25rem 1.5rem;">
  <div style="max-width:1280px; margin:0 auto;">

    <!-- Columns -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px,1fr)); gap:2.5rem; margin-bottom:2.5rem;">

      <!-- Showroom -->
      <div>
        <p style="font-size:1.1rem; font-weight:900; color:#fff; letter-spacing:-0.03em; margin:0 0 1rem;">BIKE<span style="color:#b5f23d;">XPERT</span></p>
        <p style="font-size:0.85rem; line-height:1.7; color:#aaa; margin:0 0 0.75rem;">
          Burg. Baumannlaan 5<br>3331 LL Zwijndrecht<br><br>
          <a href="tel:0781234567" style="color:#aaa; text-decoration:none;">078 123 45 67</a><br>
          <a href="mailto:info@bikexpert.nl" style="color:#aaa; text-decoration:none;">info@bikexpert.nl</a>
        </p>
        <p style="font-size:0.82rem; color:#777; line-height:1.8;">
          Openingstijden:<br>
          Di � Vr: 10:00 � 18:00<br>
          Za: 10:00 � 17:00<br>
          Zo + Ma: Gesloten
        </p>
      </div>

      <!-- Fietsen -->
      <div>
        <p style="font-size:0.8rem; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Fietsen</p>
        <ul style="list-style:none; margin:0; padding:0; font-size:0.875rem; line-height:2.1;">
          <li><a href="/collections/elektrische-fiets" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Elektrische fiets</a></li>
          <li><a href="/collections/damesfiets" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Damesfiets</a></li>
          <li><a href="/collections/herenfiets" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Herenfiets</a></li>
          <li><a href="/collections/mountainbike" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Mountainbike</a></li>
          <li><a href="/collections/fatbike" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Fatbike</a></li>
          <li><a href="/collections/kinderfietsen" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Kinderfietsen</a></li>
          <li><a href="/collections/accessoires" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Accessoires</a></li>
        </ul>
      </div>

      <!-- Informatie -->
      <div>
        <p style="font-size:0.8rem; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Informatie</p>
        <ul style="list-style:none; margin:0; padding:0; font-size:0.875rem; line-height:2.1;">
          <li><a href="/pages/contact" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Contact</a></li>
          <li><a href="/pages/service" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Service & reparatie</a></li>
          <li><a href="/policies/shipping-policy" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Verzending</a></li>
          <li><a href="/policies/refund-policy" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Retourneren</a></li>
          <li><a href="/policies/privacy-policy" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Privacybeleid</a></li>
        </ul>
      </div>

      <!-- Account -->
      <div>
        <p style="font-size:0.8rem; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Mijn account</p>
        <ul style="list-style:none; margin:0; padding:0; font-size:0.875rem; line-height:2.1;">
          <li><a href="/account" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Inloggen</a></li>
          <li><a href="/account/register" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Registreren</a></li>
          <li><a href="/account/orders" style="color:#aaa; text-decoration:none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">Mijn bestellingen</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid #333; padding-top:1.25rem; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:0.75rem; font-size:0.78rem; color:#666;">
      <span>� {{ 'now' | date: '%Y' }} {{ shop.name }} � Alle rechten voorbehouden</span>
      <div style="display:flex; gap:1rem;">
        <a href="{{ shop.url }}/policies/privacy-policy" style="color:#666; text-decoration:none;" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Privacy</a>
        <a href="{{ shop.url }}/policies/terms-of-service" style="color:#666; text-decoration:none;" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Algemene voorwaarden</a>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
