<!-- -- Contact page -- -->
<div style="max-width:1280px; margin:0 auto; padding:3rem 1.25rem 4rem;">

  <!-- Heading -->
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:2rem; font-weight:900; color:#0a0a0a; letter-spacing:-0.04em; margin:0 0 0.5rem;">Contact</h1>
    <p style="color:#666; font-size:1rem; margin:0;">Heb je een vraag of wil je langskomen? We helpen je graag.</p>
  </div>

  <!-- Two-column layout -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start;">

    <!-- Left: info + map -->
    <div>

      <!-- Info cards -->
      <div style="display:grid; gap:1rem; margin-bottom:2rem;">

        <!-- Address -->
        <div style="background:#f7f7f7; border-radius:10px; padding:1.25rem 1.5rem; display:flex; gap:1rem; align-items:flex-start;">
          <div style="flex-shrink:0; width:38px; height:38px; background:#b5f23d; border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p style="font-weight:700; color:#111; margin:0 0 0.25rem; font-size:0.9rem;">Adres</p>
            <p style="color:#555; font-size:0.875rem; margin:0; line-height:1.6;">Oudeland 128<br>3335 VJ Zwijndrecht</p>
          </div>
        </div>

        <!-- Phone -->
        <div style="background:#f7f7f7; border-radius:10px; padding:1.25rem 1.5rem; display:flex; gap:1rem; align-items:flex-start;">
          <div style="flex-shrink:0; width:38px; height:38px; background:#b5f23d; border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.36 2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <p style="font-weight:700; color:#111; margin:0 0 0.25rem; font-size:0.9rem;">Telefoon</p>
            <a href="tel:0614913695" style="color:#555; font-size:0.875rem; text-decoration:none;">06 149 136 95</a>
          </div>
        </div>

        <!-- Email -->
        <div style="background:#f7f7f7; border-radius:10px; padding:1.25rem 1.5rem; display:flex; gap:1rem; align-items:flex-start;">
          <div style="flex-shrink:0; width:38px; height:38px; background:#b5f23d; border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p style="font-weight:700; color:#111; margin:0 0 0.25rem; font-size:0.9rem;">E-mail</p>
            <a href="mailto:info@bikexpert.nl" style="color:#555; font-size:0.875rem; text-decoration:none;">info@bikexpert.nl</a>
          </div>
        </div>

        <!-- Opening hours -->
        <div style="background:#f7f7f7; border-radius:10px; padding:1.25rem 1.5rem; display:flex; gap:1rem; align-items:flex-start;">
          <div style="flex-shrink:0; width:38px; height:38px; background:#b5f23d; border-radius:8px; display:flex; align-items:center; justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <p style="font-weight:700; color:#111; margin:0 0 0.5rem; font-size:0.9rem;">Openingstijden</p>
            <table style="font-size:0.875rem; color:#555; border-collapse:collapse; line-height:1.8;">
              <tr><td style="padding-right:1.5rem;">Dinsdag – Vrijdag</td><td style="font-weight:600; color:#333;">10:00 – 18:00</td></tr>
              <tr><td style="padding-right:1.5rem;">Zaterdag</td><td style="font-weight:600; color:#333;">10:00 – 17:00</td></tr>
              <tr><td style="padding-right:1.5rem;">Zondag &amp; Maandag</td><td style="font-weight:600; color:#e33;">Gesloten</td></tr>
            </table>
          </div>
        </div>

      </div>

      <!-- Google Maps embed -->
      <div style="border-radius:12px; overflow:hidden; border:1px solid #e5e5e5;">
        <iframe
          title="Locatie BikeXpert"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2460.1!2d4.6333!3d51.8167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sOudeland+128%2C+3335+VJ+Zwijndrecht!5e0!3m2!1snl!2snl!4v1"
          width="100%"
          height="260"
          style="border:0; display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>

    <!-- Right: contact form -->
    <div>
      <div style="background:#fff; border:1px solid #e5e5e5; border-radius:14px; padding:2rem;">
        <h2 style="font-size:1.2rem; font-weight:800; color:#0a0a0a; margin:0 0 1.5rem; letter-spacing:-0.02em;">Stuur ons een bericht</h2>

        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <div style="background:#edffd5; border:1px solid #b5f23d; border-radius:8px; padding:1rem 1.25rem; margin-bottom:1.5rem; color:#2a5200; font-weight:600; font-size:0.9rem;">
              Bedankt voor je bericht! We nemen zo snel mogelijk contact met je op.
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div style="background:#fff0f0; border:1px solid #fca5a5; border-radius:8px; padding:1rem 1.25rem; margin-bottom:1.5rem; color:#7f1d1d; font-size:0.875rem;">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <!-- Name -->
          <div style="margin-bottom:1rem;">
            <label for="ContactFormName" style="display:block; font-size:0.82rem; font-weight:700; color:#333; margin-bottom:0.35rem; text-transform:uppercase; letter-spacing:0.05em;">Naam</label>
            <input type="text" id="ContactFormName" name="contact[name]" autocomplete="name" value="{{ form.name }}" required
              style="width:100%; padding:0.7rem 0.9rem; border:1px solid #ddd; border-radius:7px; font-size:0.9rem; outline:none; box-sizing:border-box; font-family:inherit; transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#b5f23d'" onblur="this.style.borderColor='#ddd'">
          </div>

          <!-- Email -->
          <div style="margin-bottom:1rem;">
            <label for="ContactFormEmail" style="display:block; font-size:0.82rem; font-weight:700; color:#333; margin-bottom:0.35rem; text-transform:uppercase; letter-spacing:0.05em;">E-mailadres</label>
            <input type="email" id="ContactFormEmail" name="contact[email]" autocomplete="email" value="{{ form.email }}" required
              style="width:100%; padding:0.7rem 0.9rem; border:1px solid #ddd; border-radius:7px; font-size:0.9rem; outline:none; box-sizing:border-box; font-family:inherit; transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#b5f23d'" onblur="this.style.borderColor='#ddd'">
          </div>

          <!-- Phone (optional) -->
          <div style="margin-bottom:1rem;">
            <label for="ContactFormPhone" style="display:block; font-size:0.82rem; font-weight:700; color:#333; margin-bottom:0.35rem; text-transform:uppercase; letter-spacing:0.05em;">Telefoonnummer <span style="font-weight:400; color:#999; text-transform:none;">(optioneel)</span></label>
            <input type="tel" id="ContactFormPhone" name="contact[phone]" autocomplete="tel" value="{{ form.phone }}"
              style="width:100%; padding:0.7rem 0.9rem; border:1px solid #ddd; border-radius:7px; font-size:0.9rem; outline:none; box-sizing:border-box; font-family:inherit; transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#b5f23d'" onblur="this.style.borderColor='#ddd'">
          </div>

          <!-- Message -->
          <div style="margin-bottom:1.5rem;">
            <label for="ContactFormMessage" style="display:block; font-size:0.82rem; font-weight:700; color:#333; margin-bottom:0.35rem; text-transform:uppercase; letter-spacing:0.05em;">Bericht</label>
            <textarea id="ContactFormMessage" name="contact[body]" rows="5" required
              style="width:100%; padding:0.7rem 0.9rem; border:1px solid #ddd; border-radius:7px; font-size:0.9rem; outline:none; box-sizing:border-box; font-family:inherit; resize:vertical; transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#b5f23d'" onblur="this.style.borderColor='#ddd'">{{ form.body }}</textarea>
          </div>

          <button type="submit"
            style="width:100%; background:#b5f23d; color:#111; font-weight:800; font-size:0.95rem; padding:0.85rem 1rem; border:none; border-radius:8px; cursor:pointer; letter-spacing:-0.01em; transition:background 0.2s;"
            onmouseover="this.style.background='#a3e030'" onmouseout="this.style.background='#b5f23d'">
            Verstuur bericht
          </button>

        {%- endform -%}
      </div>
    </div>

  </div>
</div>

<!-- Responsive -->
<style>
  @media (max-width: 768px) {
    .bx-contact-grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Contact",
  "settings": []
}
{% endschema %}
