<!-- -- Aanbevolen producten -- -->
{%- assign col = collections[section.settings.collection] -%}
<section style="background:#fff; padding:2.5rem 0; border-top:1px solid #eee;">
  <div style="max-width:1280px; margin:0 auto; padding:0 1.25rem;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.5rem;">
      <h2 style="font-size:1.4rem; font-weight:800; color:#111; margin:0;">
        {%- if section.settings.title != blank -%}{{ section.settings.title }}{%- else -%}Aanbevolen producten{%- endif -%}
      </h2>
      {%- if col != blank -%}
      <a href="{{ col.url }}" style="font-size:0.85rem; font-weight:600; color:#0066cc; text-decoration:none;">Bekijk collectie ?</a>
      {%- endif -%}
    </div>

    {%- if col != blank -%}
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); gap:1.25rem;">
      {%- for product in col.products limit: section.settings.products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
    {%- else -%}
    <p style="color:#999; font-size:0.9rem;">Stel een collectie in via de Theme Editor.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Aanbevolen producten",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "Aanbevolen producten"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Aantal producten"
    }
  ],
  "presets": [
    {
      "name": "Aanbevolen producten"
    }
  ]
}
{% endschema %}
