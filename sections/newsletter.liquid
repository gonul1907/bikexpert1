<!-- -- Newsletter -- -->
<section style="background:#111; padding:3rem 1.25rem;">
  <div style="max-width:560px; margin:0 auto; text-align:center;">
    <h2 style="font-size:1.5rem; font-weight:800; color:#fff; margin:0 0 0.5rem;">Altijd op de hoogte?</h2>
    <p style="color:#aaa; margin:0 0 1.5rem; font-size:0.9rem;">Schrijf je in voor de nieuwsbrief en ontvang als eerste onze aanbiedingen.</p>
    {% form 'customer' %}
      {{ form.errors | default_errors }}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div style="display:flex; gap:0; border-radius:6px; overflow:hidden; border:1px solid #333;">
        <input type="email" name="contact[email]" placeholder="Jouw e-mailadres" required autocomplete="email"
          style="flex:1; padding:0.75rem 1rem; background:#1a1a1a; color:#fff; border:none; outline:none; font-size:0.9rem;">
        <button type="submit" style="background:#b5f23d; color:#111; font-weight:700; padding:0.75rem 1.25rem; border:none; cursor:pointer; font-size:0.85rem; white-space:nowrap;">Inschrijven</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Nieuwsbrief",
  "settings": []
}
{% endschema %}
