<!-- Mobile breakpoint -->
<style>
  @media (max-width: 860px) {
    #site-header nav:not(#mobile-menu) { display:none !important; }
    #mobile-menu-btn { display:flex !important; }
  }
</style>

<script>
  document.getElementById('search-toggle').addEventListener('click', function() {
    var bar = document.getElementById('search-bar');
    bar.style.display = bar.style.display === 'none' ? 'block' : 'none';
    if (bar.style.display === 'block') bar.querySelector('input').focus();
  });
  document.getElementById('mobile-menu-btn').addEventListener('click', function() {
    var m = document.getElementById('mobile-menu');
    m.style.display = m.style.display === 'none' ? 'block' : 'none';
  });

  // Dropdown hover
  document.querySelectorAll('.bx-dropdown').forEach(function(dd) {
    var menu = dd.querySelector('.bx-dropdown-menu');
    dd.addEventListener('mouseenter', function() { menu.style.display = 'block'; });
    dd.addEventListener('mouseleave', function() { menu.style.display = 'none'; });
    dd.querySelector('.bx-dropdown-btn').addEventListener('click', function() {
      menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    });
  });
</script>

