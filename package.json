{
  "name": "bikexpert",
  "version": "1.0.0",
  "description": "Bikexpert — Premium Dutch bicycle shop (Zwijndrecht)",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run tw:watch\" \"vite\"",
    "build": "npm run tw:build && vite build",
    "preview": "vite preview",
    "tw:watch": "tailwindcss -i assets/base.css -o assets/main.css --watch",
    "tw:build": "tailwindcss -i assets/base.css -o assets/main.css --minify"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
