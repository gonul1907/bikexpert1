<!--
  SNIPPET: snippets/announcement-bar.html
  Shopify: {% render 'announcement-bar' %}
-->
<div
  class="announcement-bar"
  data-announcement-bar
  role="region"
  aria-label="Aankondiging"
>
  <div class="bx-container flex items-center justify-center gap-4 relative">
    <!-- Messages rotate via JS marquee or static -->
    <p class="flex items-center gap-2">
      <span class="text-bx-accent font-bold">✦</span>
      Gratis bezorging vanaf €99 &nbsp;·&nbsp; Showroom open di–za 10–18u &nbsp;·&nbsp; 0-rente financiering beschikbaar
      <span class="text-bx-accent font-bold">✦</span>
    </p>
    <!-- Dismiss -->
    <button
      data-announcement-dismiss
      class="absolute right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors"
      aria-label="Sluit aankondiging"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>
