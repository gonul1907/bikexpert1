<!--
  SNIPPET: snippets/product-card.html
  Shopify: {% render 'product-card', product: product %}

  Variables expected:
    - card_title       (string)
    - card_subtitle    (string, e.g. brand)
    - card_price       (string, e.g. "€ 3.499")
    - card_price_old   (string, optional)
    - card_img         (url)
    - card_img_hover   (url, optional)
    - card_href        (url)
    - card_badge       (string, optional: 'new' | 'sale' | 'top')
    - card_badge_label (string)
-->
<article class="product-card" aria-label="{{ card_title }}">
  <!-- Image -->
  <a href="{{ card_href }}" class="product-card__img block" tabindex="-1" aria-hidden="true">
    <img
      src="{{ card_img }}"
      alt="{{ card_title }}"
      width="600"
      height="450"
      loading="lazy"
      decoding="async"
    >
    <!-- Quick-add overlay -->
    <div class="absolute inset-0 flex items-end justify-center pb-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <button
        class="btn-primary btn text-sm py-3 px-6 shadow-lg"
        data-cart-open
        aria-label="Voeg {{ card_title }} toe aan winkelwagen"
      >
        In winkelmand
      </button>
    </div>
    <!-- Badge -->
    {% if card_badge %}
    <div class="absolute top-4 left-4">
      <span class="badge-{{ card_badge }}">{{ card_badge_label }}</span>
    </div>
    {% endif %}
  </a>

  <!-- Body -->
  <div class="product-card__body">
    {% if card_subtitle %}
    <p class="text-xs text-bx-muted font-medium uppercase tracking-widest mb-1">{{ card_subtitle }}</p>
    {% endif %}
    <h3 class="font-semibold text-base leading-tight mb-2 truncate">
      <a href="{{ card_href }}" class="hover:text-bx-muted transition-colors">{{ card_title }}</a>
    </h3>
    <div class="flex items-baseline gap-2">
      <span class="text-base font-bold">{{ card_price }}</span>
      {% if card_price_old %}
      <span class="text-sm text-bx-muted line-through">{{ card_price_old }}</span>
      {% endif %}
    </div>
  </div>
</article>
