{%- liquid
  assign card_title      = product.title
  assign card_href       = product.url
  assign card_subtitle   = product.vendor
  assign card_price      = product.price | money
  assign card_price_old  = nil
  if product.compare_at_price > product.price
    assign card_price_old = product.compare_at_price | money
  endif
  assign card_img = product.featured_image | image_url: width: 600
-%}
<article class="product-card group" aria-label="{{ card_title | escape }}">
  <!-- Image -->
  <a href="{{ card_href }}" class="product-card__img block relative overflow-hidden" tabindex="-1" aria-hidden="true">
    <img
      src="{{ card_img }}"
      alt="{{ card_title | escape }}"
      width="600"
      height="450"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    >
    <!-- Quick-add overlay -->
    <div class="absolute inset-0 flex items-end justify-center pb-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <button
        class="btn-primary btn text-sm py-3 px-6 shadow-lg"
        data-cart-open
        aria-label="Voeg {{ card_title | escape }} toe aan winkelwagen"
      >
        In winkelmand
      </button>
    </div>
    <!-- Badge -->
    {%- if product.available == false -%}
    <div class="absolute top-4 left-4">
      <span class="bg-[#6b7280] text-white text-xs font-bold px-3 py-1 rounded-full">Uitverkocht</span>
    </div>
    {%- elsif product.compare_at_price > product.price -%}
    <div class="absolute top-4 left-4">
      <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full">Sale</span>
    </div>
    {%- elsif product.created_at > 'now' | date_minus: 30 | date: '%s' -%}
    <div class="absolute top-4 left-4">
      <span class="bg-[#b5f23d] text-[#0a0a0a] text-xs font-bold px-3 py-1 rounded-full">Nieuw</span>
    </div>
    {%- endif -%}
  </a>

  <!-- Body -->
  <div class="product-card__body p-4">
    {%- if card_subtitle != blank -%}
    <p class="text-xs text-bx-muted font-medium uppercase tracking-widest mb-1">{{ card_subtitle }}</p>
    {%- endif -%}
    <h3 class="font-semibold text-base leading-tight mb-2 truncate">
      <a href="{{ card_href }}" class="hover:text-bx-muted transition-colors">{{ card_title }}</a>
    </h3>
    <div class="flex items-baseline gap-2">
      <span class="text-base font-bold">{{ card_price }}</span>
      {%- if card_price_old -%}
      <span class="text-sm text-bx-muted line-through">{{ card_price_old }}</span>
      {%- endif -%}
    </div>
  </div>
</article>
