<div style="background:#fff; border:1px solid #eee; border-radius:8px; overflow:hidden; display:flex; flex-direction:column; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
  <a href="{{ product.url }}" style="display:block; overflow:hidden;">
    {%- if product.featured_image -%}
    <img
      src="{{ product.featured_image | image_url: width: 600 }}"
      alt="{{ product.featured_image.alt | escape }}"
      width="600" height="600"
      style="width:100%; height:220px; object-fit:cover; transition:transform 0.4s; display:block;"
      loading="lazy"
      decoding="async"
      onmouseover="this.style.transform='scale(1.05)'"
      onmouseout="this.style.transform='scale(1)'"
    >
    {%- else -%}
    <div style="width:100%; height:220px; background:#f3f3f3; display:flex; align-items:center; justify-content:center; color:#bbb; font-size:0.8rem;">Geen afbeelding</div>
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
    <span style="position:absolute; top:10px; left:10px; background:#e53935; color:#fff; font-size:0.7rem; font-weight:700; padding:3px 8px; border-radius:4px; letter-spacing:0.05em;">SALE</span>
    {%- endif -%}
    {%- unless product.available -%}
    <span style="position:absolute; top:10px; left:10px; background:#9e9e9e; color:#fff; font-size:0.7rem; font-weight:700; padding:3px 8px; border-radius:4px;">UITVERKOCHT</span>
    {%- endunless -%}
  </a>
  <div style="padding:0.85rem; flex:1; display:flex; flex-direction:column;">
    {%- if product.vendor != blank -%}
    <p style="font-size:0.72rem; font-weight:700; color:#0066cc; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 0.3rem;">{{ product.vendor }}</p>
    {%- endif -%}
    <a href="{{ product.url }}" style="text-decoration:none; color:#111; font-weight:700; font-size:0.9rem; line-height:1.35; flex:1; display:block; margin-bottom:0.6rem;">{{ product.title }}</a>
    <div>
      {%- if product.compare_at_price > product.price -%}
      <p style="font-size:0.75rem; color:#999; margin:0;">Adviesprijs <s>{{ product.compare_at_price | money }}</s></p>
      <p style="font-size:1rem; font-weight:800; color:#e53935; margin:0.1rem 0 0;">Vanaf {{ product.price | money }}</p>
      {%- else -%}
      <p style="font-size:1rem; font-weight:800; color:#111; margin:0;">{{ product.price | money }}</p>
      {%- endif -%}
    </div>
    <a href="{{ product.url }}" style="display:block; margin-top:0.75rem; background:#111; color:#fff; font-size:0.8rem; font-weight:700; padding:0.55rem; border-radius:5px; text-align:center; text-decoration:none; transition:background 0.2s;" onmouseover="this.style.background='#b5f23d'; this.style.color='#111'" onmouseout="this.style.background='#111'; this.style.color='#fff'">Bekijk product</a>
  </div>
</div>
