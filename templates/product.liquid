<div class="bx-container py-16">
  <h1 class="text-4xl font-black mb-4">{{ product.title }}</h1>
  <p class="text-2xl font-bold mb-4">{{ product.price | money }}</p>
  <div class="prose mb-8">{{ product.description }}</div>
  <form action="/cart/add" method="post">
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="inline-flex items-center gap-2 bg-[#0a0a0a] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#b5f23d] hover:text-[#0a0a0a] transition-all duration-300">
      In winkelwagen
    </button>
  </form>
</div>
