<div class="bx-container py-16">

  <!-- Header -->
  <div class="mb-10">
    <p class="text-xs font-semibold tracking-[.2em] uppercase text-[#6b7280] mb-2">Collectie</p>
    <h1 class="text-4xl font-black tracking-tight">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
    <div class="mt-3 text-[#6b7280] max-w-2xl">{{ collection.description }}</div>
    {%- endif -%}
    <p class="mt-2 text-sm text-[#6b7280]">{{ collection.products_count }} producten</p>
  </div>

  <!-- Product grid -->
  {%- if collection.products.size > 0 -%}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {%- for product in collection.products -%}
      {%- render 'product-card', product: product -%}
    {%- endfor -%}
  </div>

  <!-- Pagination -->
  {%- if paginate.pages > 1 -%}
  <div class="mt-12 flex justify-center gap-2">
    {{- paginate | default_pagination -}}
  </div>
  {%- endif -%}

  {%- else -%}
  <div class="py-24 text-center">
    <p class="text-lg text-[#6b7280]">Geen producten gevonden in deze collectie.</p>
    <a href="/collections/all" class="mt-6 inline-flex items-center gap-2 bg-[#0a0a0a] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#b5f23d] hover:text-[#0a0a0a] transition-all duration-300">
      Bekijk alle producten
    </a>
  </div>
  {%- endif -%}

</div>
