<div class="bx-container py-16">

  <!-- Header -->
  <div class="mb-10">
    <p class="text-xs font-semibold tracking-[.2em] uppercase text-[#6b7280] mb-2">Collectie</p>
    <h1 class="text-4xl font-black tracking-tight">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
    <div class="mt-3 text-[#6b7280] max-w-2xl">{{ collection.description }}</div>
    {%- endif -%}
    <p class="mt-2 text-sm text-[#6b7280]" id="bx-product-count">{{ collection.products_count }} producten</p>
  </div>

  <!-- Subcategorieën kinderfietsen -->
  {%- if collection.handle == 'kinderfietsen' -%}
  <div class="grid grid-cols-2 gap-4 mb-10">
    <a href="/collections/jongensfietsen" class="group relative block rounded-2xl overflow-hidden aspect-[3/2] bg-bx-gray">
      <img
        src="https://www.volare-kinderfietsen.nl/cdn/shop/files/Disney_Cars_Kinderfiets_-_Jongens_-_12_inch_-_Twee_handremmen_-_1-W1800_8984d723-2efa-4f96-bc5c-4e9ab59eda38.jpg?v=1779840144"
        alt="Jongensfietsen"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      >
      <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/15 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-5">
        <h3 class="text-white font-black text-lg leading-tight mb-2">Alle jongensfietsen</h3>
        <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
          Bekijk collectie
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    </a>
    <a href="/collections/meisjesfietsen" class="group relative block rounded-2xl overflow-hidden aspect-[3/2] bg-bx-gray">
      <img
        src="https://images.unsplash.com/photo-1520872024865-3ff2805d8bb3?w=600&q=80&auto=format&fit=crop"
        alt="Meisjesfietsen"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      >
      <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/15 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-5">
        <h3 class="text-white font-black text-lg leading-tight mb-2">Alle meisjesfietsen</h3>
        <span class="inline-flex items-center gap-1.5 text-white text-sm font-semibold group-hover:gap-3 transition-all duration-300">
          Bekijk collectie
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </div>
    </a>
  </div>
  {%- endif -%}

  {%- if collection.products.size > 0 -%}

  <!-- Merkfilters -->
  {%- assign vendors = collection.products | map: 'vendor' | uniq | sort -%}
  {%- if vendors.size > 1 -%}
  <div class="flex flex-wrap gap-2 mb-8" id="bx-filters">
    <button
      class="bx-filter-btn px-4 py-2 rounded-full text-sm font-semibold border-2 border-[#0a0a0a] bg-[#0a0a0a] text-white transition-all duration-200"
      data-vendor="all"
      onclick="bxFilter(this)"
    >Alle merken</button>
    {%- for vendor in vendors -%}
    <button
      class="bx-filter-btn px-4 py-2 rounded-full text-sm font-semibold border-2 border-[#e5e7eb] bg-white text-[#0a0a0a] hover:border-[#0a0a0a] transition-all duration-200"
      data-vendor="{{ vendor | escape }}"
      onclick="bxFilter(this)"
    >{{ vendor }}</button>
    {%- endfor -%}
  </div>
  {%- endif -%}

  <!-- Product grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="bx-product-grid">
    {%- for product in collection.products -%}
    <div class="bx-product-item" data-vendor="{{ product.vendor | escape }}">
      {%- render 'product-card', product: product -%}
    </div>
    {%- endfor -%}
  </div>

  <!-- Geen resultaten bij filter -->
  <p class="hidden py-16 text-center text-[#6b7280]" id="bx-no-results">Geen producten gevonden voor dit merk.</p>

  <!-- Pagination -->
  {%- if paginate.pages > 1 -%}
  <div class="mt-12 flex justify-center gap-2">
    {{- paginate | default_pagination -}}
  </div>
  {%- endif -%}

  <script>
    function bxFilter(btn) {
      var vendor = btn.getAttribute('data-vendor');
      var items = document.querySelectorAll('.bx-product-item');
      var visible = 0;

      items.forEach(function(item) {
        if (vendor === 'all' || item.getAttribute('data-vendor') === vendor) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      // Update actieve knop
      document.querySelectorAll('.bx-filter-btn').forEach(function(b) {
        if (b === btn) {
          b.classList.add('bg-[#0a0a0a]', 'text-white', 'border-[#0a0a0a]');
          b.classList.remove('bg-white', 'text-[#0a0a0a]', 'border-[#e5e7eb]');
        } else {
          b.classList.remove('bg-[#0a0a0a]', 'text-white', 'border-[#0a0a0a]');
          b.classList.add('bg-white', 'text-[#0a0a0a]', 'border-[#e5e7eb]');
        }
      });

      // Update teller en lege staat
      var countEl = document.getElementById('bx-product-count');
      if (countEl) countEl.textContent = visible + ' producten';
      var noResults = document.getElementById('bx-no-results');
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }
  </script>

  {%- else -%}
  <div class="py-24 text-center">
    <p class="text-lg text-[#6b7280]">Geen producten gevonden in deze collectie.</p>
    <a href="/collections/all" class="mt-6 inline-flex items-center gap-2 bg-[#0a0a0a] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#b5f23d] hover:text-[#0a0a0a] transition-all duration-300">
      Bekijk alle producten
    </a>
  </div>
  {%- endif -%}

</div>
