<div style="max-width:900px; margin:3rem auto; padding:0 1.25rem;">
  <h1 style="font-size:1.6rem; font-weight:800; color:#111; margin-bottom:2rem;">Winkelwagen</h1>

  {% if cart.item_count == 0 %}
    <div style="text-align:center; padding:4rem 0; color:#666;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" style="margin-bottom:1rem;"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <p style="font-size:1.1rem; font-weight:600; margin-bottom:0.5rem;">Je winkelwagen is leeg</p>
      <p style="font-size:0.9rem; margin-bottom:1.5rem;">Voeg producten toe om verder te gaan.</p>
      <a href="/collections/all" style="background:#b5f23d; color:#111; font-weight:700; padding:0.75rem 2rem; border-radius:6px; text-decoration:none; font-size:0.95rem;">Bekijk alle fietsen</a>
    </div>
  {% else %}
    <form action="/cart" method="post">
      <table style="width:100%; border-collapse:collapse; margin-bottom:2rem;">
        <thead>
          <tr style="border-bottom:2px solid #eee; text-align:left;">
            <th style="padding:0.75rem 0; font-size:0.82rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Product</th>
            <th style="padding:0.75rem 0; font-size:0.82rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Prijs</th>
            <th style="padding:0.75rem 0; font-size:0.82rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Aantal</th>
            <th style="padding:0.75rem 0; font-size:0.82rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; text-align:right;">Totaal</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
          <tr style="border-bottom:1px solid #f2f2f2;">
            <td style="padding:1rem 0; display:flex; align-items:center; gap:1rem;">
              {% if item.image %}
              <img src="{{ item.image | image_url: width: 80 }}" alt="{{ item.title }}" style="width:70px; height:70px; object-fit:contain; border-radius:6px; border:1px solid #eee;">
              {% endif %}
              <div>
                <a href="{{ item.url }}" style="font-weight:700; color:#111; text-decoration:none; font-size:0.9rem;">{{ item.product.title }}</a>
                {% if item.variant.title != 'Default Title' %}
                <div style="font-size:0.8rem; color:#888; margin-top:0.2rem;">{{ item.variant.title }}</div>
                {% endif %}
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="font-size:0.78rem; color:#e44; text-decoration:none; margin-top:0.4rem; display:inline-block;">Verwijderen</a>
              </div>
            </td>
            <td style="padding:1rem 0.5rem; font-size:0.9rem; color:#333;">{{ item.original_price | money }}</td>
            <td style="padding:1rem 0.5rem;">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="1" style="width:60px; padding:0.4rem 0.5rem; border:1px solid #ddd; border-radius:5px; font-size:0.9rem; text-align:center;">
            </td>
            <td style="padding:1rem 0; font-size:0.9rem; font-weight:700; color:#111; text-align:right;">{{ item.final_line_price | money }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:1.5rem;">
        <button type="submit" name="update" style="background:#f0f0f0; color:#333; border:none; padding:0.7rem 1.5rem; border-radius:6px; font-weight:600; cursor:pointer; font-size:0.9rem;">Wagen bijwerken</button>
        <div style="text-align:right;">
          <div style="font-size:0.9rem; color:#666; margin-bottom:0.4rem;">Subtotaal</div>
          <div style="font-size:1.4rem; font-weight:800; color:#111; margin-bottom:1rem;">{{ cart.total_price | money }}</div>
          <p style="font-size:0.8rem; color:#888; margin-bottom:1rem;">Verzendkosten worden berekend bij het afrekenen.</p>
          <a href="/checkout" style="display:block; background:#b5f23d; color:#111; font-weight:800; padding:0.85rem 2.5rem; border-radius:6px; text-decoration:none; font-size:1rem; text-align:center;">Afrekenen</a>
        </div>
      </div>
    </form>
  {% endif %}
</div>